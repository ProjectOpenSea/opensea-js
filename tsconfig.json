{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "lib",
    "rootDir": ".",
    "lib": ["dom", "esnext"],
    "types": ["vitest/globals"],
    "module": "commonjs",
    "moduleResolution": "node",
    "noImplicitReturns": true,
    "noErrorTruncation": true,
    "noImplicitThis": false,
    "noUnusedParameters": true,
    "preserveConstEnums": true,
    "removeComments": false,
    "sourceMap": true,
    "baseUrl": "."
  },
  "include": ["./src/**/*", "test"]
}
