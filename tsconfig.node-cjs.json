{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["dom", "esnext"],
    "module": "commonjs",
    "moduleResolution": "node",
    "noImplicitReturns": true,
    "noErrorTruncation": true,
    "noImplicitThis": false,
    "noUnusedParameters": true,
    "preserveConstEnums": true,
    "removeComments": false,
    "sourceMap": true
  }
}
